{
  "manifest_version": 3,
  "name": "Better Do colon brackets",
  "version": "1.1",
  "description": "Replaces :) and :3 with :] (toggle + live)",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
  "permissions": ["storage"],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
