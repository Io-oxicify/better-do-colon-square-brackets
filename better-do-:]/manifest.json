{
  "manifest_version": 3,
  "name": "Emoji Fixer Live",
  "version": "1.1",
  "description": "Replaces :) and :3 with :] (toggle + live)",
  
  "permissions": ["storage"],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
